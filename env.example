const test=require('node:test');const assert=require('node:assert/strict');const fs=require('fs');const path=require('path');
const source=fs.readFileSync(path.join(__dirname,'..','server.js'),'utf8');
test('DBServer health queries Turso',()=>{assert.match(source,/app\.get\('\/api\/health'/);assert.match(source,/await db\.execute\('SELECT 1'\)/)});
test('DBServer database health reports snapshots',()=>{assert.match(source,/\/api\/health\/database/);assert.match(source,/snapshotCount/);assert.match(source,/latestSnapshot/)});
test('DBServer remains protected for snapshot APIs',()=>{assert.match(source,/app\.use\('\/api',auth\)/)});
test('DBServer version is 4.2.0',()=>assert.match(source,/VERSION='4\.2\.0'/));
